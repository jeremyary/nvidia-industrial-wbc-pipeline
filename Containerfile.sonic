# This project was developed with assistance from AI tools.
# Lightweight container for SONIC checkpoint import pipeline.
# Pulls pre-trained ONNX models from HuggingFace, validates, and registers.
FROM python:3.12-slim

WORKDIR /app
COPY pyproject.toml .
COPY src/ src/

RUN pip install --no-cache-dir ".[deploy]"

USER 1001
