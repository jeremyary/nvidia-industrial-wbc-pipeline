# NGC token for Isaac Sim container pull
NGC_API_KEY=your-token-here

# MLflow tracking (RHOAI-managed or local)
MLFLOW_TRACKING_URI=http://mlflow.example.com:5000
MLFLOW_EXPERIMENT_NAME=g1-wbc-training

# S3-compatible storage for checkpoints and artifacts
S3_ENDPOINT=https://minio.example.com
S3_BUCKET=wbc-training
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
